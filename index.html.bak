  <div class="footer-links">
    <span class="footer-link" onclick="goTo('overview')">Επισκόπηση</span>
    <span class="footer-link" onclick="goTo('accommodation')">Κατάλυμα</span>
    <span class="footer-link" onclick="goTo('itinerary')">Πρόγραμμα</span>
    <span class="footer-link" onclick="goTo('maps')">Χάρτης</span>
    <span class="footer-link" onclick="goTo('packing')">Αποσκευές</span>
  </div>
</footer>

<script>
// Day tabs
function showDay(n, btn) {
  document.querySelectorAll('.day-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.dtab').forEach(b => b.classList.remove('active'));
  document.getElementById('day' + n).classList.add('active');
  if (btn) btn.classList.add('active');
  else document.querySelectorAll('.dtab')[n-1]?.classList.add('active');
}
// Scroll to section + activate nav
function goTo(id, btn) {
  const el = document.getElementById(id);
  if (!el) return;
  const offset = document.querySelector('.sticky-nav')?.offsetHeight || 44;
  const top = el.getBoundingClientRect().top + window.scrollY - offset - 8;
  window.scrollTo({ top, behavior: 'smooth' });
}
// Packing tick
function tick(li) {
  li.classList.toggle('done');
  li.querySelector('.pack-box').textContent = li.classList.contains('done') ? '✓' : '';
}
// Active nav on scroll
const navSecs = ['overview','accommodation','itinerary','maps','packing'];
const navBtns = document.querySelectorAll('.snav-btn');
const stickyH = () => document.querySelector('.sticky-nav')?.offsetHeight || 44;
window.addEventListener('scroll', () => {
  let cur = navSecs[0];
  navSecs.forEach(id => {
    const el = document.getElementById(id);
    if (el && window.scrollY >= el.getBoundingClientRect().top + window.scrollY - stickyH() - 20) cur = id;
  });
  navBtns.forEach((b, i) => b.classList.toggle('active', navSecs[i] === cur));
}, { passive: true });
</script>
</body>
</html>
