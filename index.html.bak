<!DOCTYPE html>
<html lang="el">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Αρμενία 2026 · 21–27 Μαρτίου</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,700;1,9..144,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   VARIABLES & RESET
═══════════════════════════════════════════════════ */
:root{
  --red:     #7C1515;
  --red-lt:  #f5e8e8;
  --gold:    #B8820A;
  --gold-lt: #FDF3DC;
  --ink:     #1A1210;
  --body:    #3A3028;
  --muted:   #78706A;
  --line:    #E5DDD5;
  --bg:      #F9F7F4;
  --white:   #FFFFFF;
  --warm:    #F3EDE4;
  --blue:    #1A5C8B;
  --blue-lt: #EAF3FA;
  --green:   #1A6B3A;
  --green-lt:#E8F5EE;
  --purple:  #5C2D8B;
  --purple-lt:#F0EAF8;
  --orange:  #B85A0A;
  --orange-lt:#FDF0E5;
  --r: 1rem;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--bg);color:var(--ink);line-height:1.5;-webkit-text-size-adjust:100%}
a{text-decoration:none;color:inherit}
button{font-family:inherit;cursor:pointer}
img{display:block;width:100%}

/* ═══════════════════════════════════════════════════
   COVER / HERO — full bleed Armenia gradient
═══════════════════════════════════════════════════ */
.cover{
  background: linear-gradient(155deg, #3B0A0A 0%, #7C1515 35%, #B8820A 70%, #3B0A0A 100%);
  color:white;
  padding: 2.5rem 1.5rem 3rem;
  position:relative;
  overflow:hidden;
  min-height: 320px;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
}
.cover::before{
  content:'';
  position:absolute;
  inset:0;
  background:
    radial-gradient(ellipse 60% 50% at 80% 20%, rgba(184,130,10,.35) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 10% 80%, rgba(124,21,21,.5) 0%, transparent 60%);
}
.cover-deco{
  position:absolute;
  top:-30px; right:-30px;
  width:220px; height:220px;
  border-radius:50%;
  background: radial-gradient(circle, rgba(184,130,10,.25) 0%, transparent 70%);
}
.cover-flag{
  display:flex;
  width:42px; height:26px;
  border-radius:3px;
  overflow:hidden;
  margin-bottom:1rem;
  box-shadow:0 2px 10px rgba(0,0,0,.4);
  position:relative;z-index:1;
}
.cover-flag div{flex:1}
.fr{background:#D90012}.fb{background:#0033A0}.fo{background:#F2A800}
.cover-eyebrow{
  font-size:.65rem;letter-spacing:.3em;text-transform:uppercase;
  color:rgba(255,255,255,.6);margin-bottom:.5rem;
  position:relative;z-index:1;
}
.cover-title{
  font-family:'Fraunces',serif;
  font-size:clamp(2.6rem, 8vw, 4.5rem);
  font-weight:700;line-height:.95;
  letter-spacing:-.03em;
  position:relative;z-index:1;
  margin-bottom:.5rem;
}
.cover-title em{font-style:italic;color:#E8B45A}
.cover-sub{
  font-size:.8rem;color:rgba(255,255,255,.65);
  position:relative;z-index:1;margin-bottom:1.5rem;
}
/* Stats row */
.cover-stats{
  display:flex;gap:1.5rem;flex-wrap:wrap;
  position:relative;z-index:1;
}
.cs{border-left:2px solid rgba(184,130,10,.6);padding-left:.8rem}
.cs-n{font-family:'Fraunces',serif;font-size:1.4rem;font-weight:700;line-height:1;color:white}
.cs-l{font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.5);margin-top:.15rem}

/* ═══════════════════════════════════════════════════
   TRAVELER CHIPS (below cover)
═══════════════════════════════════════════════════ */
.travelers-strip{
  background:var(--white);
  border-bottom:1px solid var(--line);
  padding:.75rem 1.25rem;
  display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;
}
.travelers-lbl{
  font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;
  color:var(--muted);flex-shrink:0;
}
.couple-pill{
  display:flex;align-items:center;gap:.45rem;
  background:var(--warm);border:1px solid var(--line);
  border-radius:100px;padding:.3rem .75rem .3rem .4rem;
}
.av-stack{display:flex}
.av{
  width:26px;height:26px;border-radius:50%;
  border:2px solid white;
  display:flex;align-items:center;justify-content:center;
  font-size:.68rem;font-weight:700;color:white;flex-shrink:0;
}
.av+.av{margin-left:-7px}
.av-red{background:linear-gradient(135deg,#8B1A1A,#C05030)}
.av-blue{background:linear-gradient(135deg,#1A5C8B,#2E86C1)}
.pill-heart{font-size:.65rem;color:#e05c7a}
.pill-names{font-size:.75rem;font-weight:700;color:var(--ink)}
.strip-divider{width:1px;height:24px;background:var(--line);flex-shrink:0;display:none}
@media(min-width:600px){.strip-divider{display:block}}
.trip-info{display:flex;align-items:center;gap:.35rem;font-size:.72rem;color:var(--body)}
.trip-info strong{color:var(--ink)}

/* ═══════════════════════════════════════════════════
   STICKY NAV
═══════════════════════════════════════════════════ */
.sticky-nav{
  position:sticky;top:0;z-index:100;
  background:rgba(255,255,255,.97);
  backdrop-filter:blur(10px);
  border-bottom:1px solid var(--line);
}
.sticky-nav-inner{
  display:flex;align-items:center;gap:0;
  overflow-x:auto;scrollbar-width:none;
  -webkit-overflow-scrolling:touch;
}
.sticky-nav-inner::-webkit-scrollbar{display:none}
.snav-btn{
  flex-shrink:0;
  padding:.7rem .9rem;
  font-size:.7rem;font-weight:600;
  color:var(--muted);background:none;border:none;
  border-bottom:2px solid transparent;
  letter-spacing:.02em;white-space:nowrap;
  transition:all .15s;
}
.snav-btn:hover{color:var(--red)}
.snav-btn.active{color:var(--red);border-bottom-color:var(--red)}

/* ═══════════════════════════════════════════════════
   LAYOUT WRAPPER
═══════════════════════════════════════════════════ */
.page{max-width:720px;margin:0 auto;padding:0 1rem}
@media(min-width:768px){.page{padding:0 1.5rem}}

/* ═══════════════════════════════════════════════════
   SECTION HEADERS
═══════════════════════════════════════════════════ */
.sec{padding:2rem 0 .5rem}
.sec-tag{
  display:inline-block;
  background:var(--red-lt);border:1px solid rgba(124,21,21,.15);
  border-radius:100px;padding:.2rem .7rem;
  font-size:.6rem;font-weight:700;letter-spacing:.12em;
  text-transform:uppercase;color:var(--red);margin-bottom:.5rem;
}
.sec-title{
  font-family:'Fraunces',serif;
  font-size:clamp(1.5rem,5vw,2.2rem);
  font-weight:700;color:var(--ink);
  line-height:1.1;letter-spacing:-.02em;margin-bottom:.4rem;
}
.sec-title em{font-style:italic;color:var(--red)}
.sec-sub{font-size:.82rem;color:var(--muted);line-height:1.6}
.divider{height:1px;background:var(--line);margin:0}

/* ═══════════════════════════════════════════════════
   OVERVIEW GRID
═══════════════════════════════════════════════════ */
.ov-grid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:.6rem;margin-top:1.2rem;
}
@media(min-width:480px){.ov-grid{grid-template-columns:repeat(3,1fr)}}
.ov-card{
  background:var(--white);border:1px solid var(--line);
  border-radius:12px;padding:1rem;
}
.ov-icon{font-size:1.3rem;margin-bottom:.4rem}
.ov-label{font-size:.58rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:.2rem}
.ov-val{font-size:.88rem;font-weight:700;color:var(--ink);line-height:1.2}
.ov-sub{font-size:.65rem;color:var(--muted);margin-top:.15rem}

/* ═══════════════════════════════════════════════════
   WEATHER ROW
═══════════════════════════════════════════════════ */
.weather-row{
  display:flex;gap:.5rem;margin-top:1.2rem;
  overflow-x:auto;padding-bottom:.5rem;
  -webkit-overflow-scrolling:touch;scrollbar-width:none;
}
.weather-row::-webkit-scrollbar{display:none}
.wcard{
  flex-shrink:0;width:78px;
  background:var(--white);border:1px solid var(--line);
  border-radius:10px;padding:.7rem .4rem;text-align:center;
}
.wc-d{font-size:.58rem;font-weight:700;color:var(--muted);letter-spacing:.05em;text-transform:uppercase}
.wc-i{font-size:1.3rem;margin:.25rem 0}
.wc-h{font-family:'Fraunces',serif;font-size:1rem;font-weight:700;color:var(--ink)}
.wc-l{font-size:.6rem;color:var(--muted)}
.wc-note{font-size:.55rem;color:var(--muted);margin-top:.25rem;line-height:1.2}

/* ═══════════════════════════════════════════════════
   AIRBNB BLOCK
═══════════════════════════════════════════════════ */
.ab-block{
  background:var(--white);border:1px solid var(--line);
  border-radius:14px;overflow:hidden;margin-top:1.2rem;
}
.ab-top{
  background:linear-gradient(135deg,#E04E54,#FF7478);
  padding:1.1rem 1.2rem;
  display:flex;align-items:center;gap:.8rem;
}
.ab-top-icon{font-size:1.5rem;flex-shrink:0}
.ab-top-title{font-family:'Fraunces',serif;font-size:1.1rem;font-weight:700;color:white}
.ab-top-sub{font-size:.65rem;color:rgba(255,255,255,.8);margin-top:.1rem}
.ab-badge{
  margin-left:auto;flex-shrink:0;
  background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.35);
  border-radius:100px;padding:.2rem .65rem;
  font-size:.62rem;font-weight:700;color:white;white-space:nowrap;
}
.ab-body{padding:1.2rem}
/* Rooms */
.ab-rooms{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin-bottom:1rem}
@media(max-width:380px){.ab-rooms{grid-template-columns:1fr}}
.ab-room{
  border-radius:10px;padding:.9rem;
  display:flex;align-items:center;gap:.7rem;
}
.ab-room-1{background:linear-gradient(135deg,rgba(124,21,21,.07),rgba(192,80,48,.04));border:1px solid rgba(124,21,21,.18)}
.ab-room-2{background:linear-gradient(135deg,rgba(26,92,139,.07),rgba(46,134,193,.04));border:1px solid rgba(26,92,139,.18)}
.room-avatars{display:flex;flex-shrink:0}
.room-info{}
.room-lbl{font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:.15rem}
.room-names{font-size:.82rem;font-weight:700;color:var(--ink)}
/* Address */
.ab-addr{
  display:flex;align-items:center;gap:.8rem;
  background:var(--warm);border:1px solid var(--line);
  border-radius:10px;padding:.85rem;flex-wrap:wrap;gap:.6rem;
}
.ab-addr-icon{font-size:1.2rem;flex-shrink:0}
.ab-addr-text{flex:1;min-width:140px}
.ab-addr-name{font-size:.85rem;font-weight:700;color:var(--ink)}
.ab-addr-sub{font-size:.65rem;color:var(--muted);margin-top:.1rem}
.map-btn{
  display:inline-flex;align-items:center;gap:.3rem;
  background:#1967D2;color:white;border-radius:7px;
  padding:.4rem .85rem;font-size:.68rem;font-weight:700;
  white-space:nowrap;border:none;transition:background .15s;
}
.map-btn:hover{background:#1558D0}

/* ═══════════════════════════════════════════════════
   DAY SELECTOR
═══════════════════════════════════════════════════ */
.day-tabs{
  display:flex;gap:.4rem;margin-top:1.2rem;
  overflow-x:auto;padding-bottom:.4rem;
  -webkit-overflow-scrolling:touch;scrollbar-width:none;
}
.day-tabs::-webkit-scrollbar{display:none}
.dtab{
  flex-shrink:0;
  background:var(--white);border:1.5px solid var(--line);
  border-radius:10px;padding:.5rem .85rem;
  font-size:.72rem;font-weight:600;color:var(--muted);
  display:flex;flex-direction:column;align-items:center;gap:.1rem;
  transition:all .15s;
}
.dtab span{font-size:.58rem;font-weight:400;opacity:.7}
.dtab:hover{border-color:var(--red);color:var(--red)}
.dtab.active{background:var(--red);border-color:var(--red);color:white}
.dtab.active span{opacity:.75}

/* ═══════════════════════════════════════════════════
   DAY PANEL
═══════════════════════════════════════════════════ */
.day-panel{display:none;animation:fadeSlide .3s ease}
.day-panel.active{display:block}
@keyframes fadeSlide{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

/* Day header banner */
.day-banner{
  border-radius:14px;padding:1.2rem;
  margin:1rem 0;
  display:flex;align-items:flex-start;gap:1rem;
  position:relative;overflow:hidden;
}
.day-banner::before{
  content:'';position:absolute;inset:0;
  background:inherit;border-radius:14px;
}
.db-num{
  width:44px;height:44px;flex-shrink:0;
  background:rgba(255,255,255,.2);
  border:2px solid rgba(255,255,255,.35);
  border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-family:'Fraunces',serif;font-size:1.4rem;font-weight:700;color:white;
  position:relative;z-index:1;
}
.db-text{position:relative;z-index:1;flex:1}
.db-day{font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.65);margin-bottom:.2rem}
.db-title{font-family:'Fraunces',serif;font-size:1.2rem;font-weight:700;color:white;line-height:1.1}
.db-meta{font-size:.68rem;color:rgba(255,255,255,.65);margin-top:.25rem;display:flex;gap:.8rem;flex-wrap:wrap}
.db-weather{
  margin-left:auto;flex-shrink:0;
  background:rgba(255,255,255,.15);
  border:1px solid rgba(255,255,255,.25);
  border-radius:8px;padding:.3rem .6rem;
  font-size:.7rem;color:white;
  display:flex;align-items:center;gap:.3rem;
  position:relative;z-index:1;white-space:nowrap;
}
/* Day banner color variants */
.db-1{background:linear-gradient(135deg,#1C3A5E,#2E6B9E)}
.db-2{background:linear-gradient(135deg,#4A1010,#8B1A1A)}
.db-3{background:linear-gradient(135deg,#1A3A1A,#2E6B2E)}
.db-4{background:linear-gradient(135deg,#3A2A0A,#8B6B1A)}
.db-5{background:linear-gradient(135deg,#3A1A1A,#6B2020)}
.db-6{background:linear-gradient(135deg,#0A2A3A,#1A6B8B)}
.db-7{background:linear-gradient(135deg,#1A2A3A,#2A4A6B)}

/* ═══════════════════════════════════════════════════
   TIMELINE
═══════════════════════════════════════════════════ */
.tl{display:flex;flex-direction:column;gap:0;padding-bottom:1rem}
.tl-row{
  display:flex;gap:0;
  position:relative;
}
/* Vertical line between items */
.tl-row:not(:last-child) .tl-line-area::after{
  content:'';
  position:absolute;
  left:50%;top:32px;
  width:1px;height:calc(100% + 1px);
  background:var(--line);
  transform:translateX(-50%);
}
.tl-line-area{
  width:44px;flex-shrink:0;
  display:flex;flex-direction:column;
  align-items:center;padding-top:12px;
  position:relative;
}
.tl-time{text-align:center}
.tl-h{font-family:'Fraunces',serif;font-size:.85rem;font-weight:700;color:var(--ink);line-height:1}
.tl-m{font-size:.55rem;color:var(--muted);letter-spacing:.05em}
.tl-dot{
  width:10px;height:10px;border-radius:50%;
  background:var(--red);margin-top:.5rem;
  box-shadow:0 0 0 3px rgba(124,21,21,.12);
  flex-shrink:0;
}
.tl-card{
  flex:1;margin:.5rem 0 .5rem .5rem;
  background:var(--white);border:1px solid var(--line);
  border-radius:12px;padding:.9rem 1rem;
  transition:border-color .15s;
}
.tl-card:hover{border-color:rgba(124,21,21,.25)}
.tl-head{display:flex;align-items:flex-start;gap:.5rem;margin-bottom:.3rem;flex-wrap:wrap}
.tl-name{font-size:.88rem;font-weight:700;color:var(--ink);line-height:1.2;flex:1;min-width:100px}
.cat-badge{
  display:inline-flex;align-items:center;
  padding:.15rem .5rem;border-radius:100px;
  font-size:.55rem;font-weight:700;letter-spacing:.05em;
  white-space:nowrap;flex-shrink:0;
}
.cat-s{background:var(--red-lt);color:var(--red)}
.cat-f{background:var(--gold-lt);color:var(--gold)}
.cat-t{background:var(--blue-lt);color:var(--blue)}
.cat-n{background:var(--purple-lt);color:var(--purple)}
.cat-x{background:var(--green-lt);color:var(--green)}
.tl-desc{font-size:.75rem;color:var(--muted);line-height:1.6;margin-bottom:.55rem}
.tl-actions{display:flex;gap:.4rem;flex-wrap:wrap}
.act{
  display:inline-flex;align-items:center;gap:.3rem;
  padding:.22rem .6rem;border-radius:6px;
  font-size:.62rem;font-weight:600;
  border:1px solid;transition:all .15s;
  white-space:nowrap;
}
.act-m{background:var(--blue-lt);color:var(--blue);border-color:#C5D8FF}
.act-m:hover{background:#C5D8FF}
.act-b{background:var(--orange-lt);color:var(--orange);border-color:#FDD5B8}
.act-b:hover{background:#FDD5B8}
.act-i{background:var(--green-lt);color:var(--green);border-color:#BBF7D0}
.act-i:hover{background:#BBF7D0}

/* ═══════════════════════════════════════════════════
   PLACE CARDS (visual scene cards without photos)
═══════════════════════════════════════════════════ */
.scene-cards{
  display:grid;grid-template-columns:1fr 1fr;gap:.6rem;
  margin:.8rem 0;
}
@media(min-width:480px){.scene-cards{grid-template-columns:repeat(3,1fr)}}
.scene-card{
  border-radius:12px;overflow:hidden;
  aspect-ratio:3/2;
  display:flex;flex-direction:column;
  justify-content:flex-end;padding:.7rem;
  position:relative;
  cursor:default;
}
.scene-card::before{
  content:'';position:absolute;inset:0;
  background:inherit;
}
.scene-card-emoji{
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-65%);
  font-size:2.2rem;opacity:.7;
}
.scene-label{
  position:relative;z-index:1;
  font-size:.65rem;font-weight:700;color:white;
  text-shadow:0 1px 4px rgba(0,0,0,.5);
  line-height:1.2;
}
.scene-sub{
  font-size:.55rem;color:rgba(255,255,255,.7);
  text-shadow:0 1px 3px rgba(0,0,0,.5);
  margin-top:.1rem;
}

/* ═══════════════════════════════════════════════════
   MAPS LIST
═══════════════════════════════════════════════════ */
.maps-list{display:flex;flex-direction:column;gap:.5rem;margin-top:1.2rem}
.map-row{
  display:flex;align-items:center;gap:.75rem;
  background:var(--white);border:1px solid var(--line);
  border-radius:10px;padding:.75rem;
  text-decoration:none;color:var(--ink);
  transition:all .15s;
}
.map-row:hover{border-color:#4285F4;background:var(--blue-lt);transform:translateX(2px)}
.map-day-dot{
  width:30px;height:30px;flex-shrink:0;
  background:var(--red);border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-family:'Fraunces',serif;font-size:.72rem;font-weight:700;color:white;
}
.map-info{flex:1}
.map-name{font-size:.82rem;font-weight:700;color:var(--ink)}
.map-cat{font-size:.63rem;color:var(--muted);margin-top:.05rem}
.map-icon{color:#4285F4;font-size:.75rem;flex-shrink:0}
.maps-import-btn{
  display:flex;align-items:center;justify-content:center;gap:.5rem;
  background:var(--ink);color:white;
  border-radius:10px;padding:.85rem;
  font-size:.78rem;font-weight:700;
  margin-top:1rem;width:100%;
  transition:background .15s;border:none;
}
.maps-import-btn:hover{background:var(--red)}

/* ═══════════════════════════════════════════════════
   PACKING LIST
═══════════════════════════════════════════════════ */
.pack-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;
  margin-top:1.2rem;
}
@media(max-width:400px){.pack-grid{grid-template-columns:1fr}}
.pack-group{}
.pack-group-title{
  font-size:.72rem;font-weight:700;color:var(--ink);
  display:flex;align-items:center;gap:.4rem;
  margin-bottom:.7rem;padding-bottom:.5rem;
  border-bottom:2px solid var(--warm);
}
.pack-ul{list-style:none;display:flex;flex-direction:column;gap:.1rem}
.pack-li{
  display:flex;align-items:center;gap:.55rem;
  padding:.3rem 0;font-size:.76rem;color:var(--body);
  cursor:pointer;user-select:none;-webkit-tap-highlight-color:transparent;
  border-radius:4px;transition:color .12s;
}
.pack-li:hover{color:var(--ink)}
.pack-li.done{color:var(--muted);text-decoration:line-through}
.pack-box{
  width:17px;height:17px;border-radius:4px;
  border:1.5px solid var(--line);flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:.6rem;color:white;transition:all .12s;
}
.pack-li.done .pack-box{background:var(--red);border-color:var(--red)}

/* ═══════════════════════════════════════════════════
   FOOTER
═══════════════════════════════════════════════════ */
.footer{
  background:var(--ink);color:white;
  padding:2rem 1.5rem;text-align:center;
  margin-top:2rem;
}
.footer-title{
  font-family:'Fraunces',serif;
  font-size:1.3rem;font-weight:700;color:#E8B45A;
  margin-bottom:.3rem;
}
.footer-sub{font-size:.72rem;opacity:.5}
.footer-couple{
  display:flex;justify-content:center;gap:.8rem;
  flex-wrap:wrap;margin-top:1rem;
}
.fc-pill{
  display:flex;align-items:center;gap:.4rem;
  background:rgba(255,255,255,.08);
  border:1px solid rgba(255,255,255,.12);
  border-radius:100px;padding:.3rem .8rem .3rem .4rem;
  font-size:.72rem;font-weight:600;color:rgba(255,255,255,.8);
}
.footer-links{
  display:flex;justify-content:center;gap:1rem;flex-wrap:wrap;
  margin-top:1.5rem;padding-top:1rem;border-top:1px solid rgba(255,255,255,.1);
}
.footer-link{font-size:.65rem;opacity:.4;cursor:pointer;transition:opacity .15s}
.footer-link:hover{opacity:.8}

/* ═══════════════════════════════════════════════════
   UTILITY
═══════════════════════════════════════════════════ */
