  .cover{padding:3rem 2rem 3.5rem}
  .page{padding:0 2rem}
}
@media(min-width:768px){
  .cover-stats .cs-n{font-size:1.6rem}
  .tl-h{font-size:.95rem}
}
</style>
</head>
<body>
<!-- ════════════════ PASSWORD SCREEN ════════════════ -->
<div id="lockScreen" style="
  position:fixed;inset:0;z-index:9999;
  background:linear-gradient(155deg,#1A0A0A 0%,#3B0A0A 40%,#7C1515 70%,#B8820A 100%);
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  font-family:'Plus Jakarta Sans',sans-serif;
">
  <!-- Deco background glow -->
  <div style="position:absolute;inset:0;
    background:radial-gradient(ellipse 50% 50% at 50% 60%,rgba(184,130,10,.2) 0%,transparent 70%);
    pointer-events:none">
  </div>

  <!-- Flag -->
  <div style="display:flex;width:52px;height:32px;border-radius:4px;overflow:hidden;
    box-shadow:0 4px 20px rgba(0,0,0,.5);margin-bottom:2rem;position:relative">
    <div style="flex:1;background:#D90012"></div>
    <div style="flex:1;background:#0033A0"></div>
    <div style="flex:1;background:#F2A800"></div>
  </div>

  <!-- Title -->
  <div style="font-family:'Fraunces',serif;font-size:clamp(2rem,7vw,3.2rem);
    font-weight:700;color:white;letter-spacing:-.03em;text-align:center;
    line-height:.95;margin-bottom:.5rem;position:relative">
    Αρμενία <span style="font-style:italic;color:#E8B45A">2026</span>
  </div>
  <div style="font-size:.68rem;letter-spacing:.3em;text-transform:uppercase;
    color:rgba(255,255,255,.45);margin-bottom:2.5rem;position:relative">
    21–27 Μαρτίου · Ερεβάν
  </div>

  <!-- Lock card -->
  <div style="
    background:rgba(255,255,255,.06);
    border:1px solid rgba(255,255,255,.12);
    border-radius:20px;padding:2rem 2rem 1.8rem;
    width:min(320px,90vw);
    backdrop-filter:blur(20px);
    position:relative;
  ">
    <div style="text-align:center;margin-bottom:1.5rem">
      <div style="font-size:1.8rem;margin-bottom:.5rem">🔒</div>
      <div style="font-size:.75rem;font-weight:600;color:rgba(255,255,255,.7);
        letter-spacing:.05em">Εισάγετε κωδικό πρόσβασης</div>
    </div>

    <!-- PIN dots display -->
    <div id="pinDots" style="display:flex;justify-content:center;gap:.8rem;margin-bottom:1.5rem">
      <div class="pin-dot" data-i="0"></div>
      <div class="pin-dot" data-i="1"></div>
      <div class="pin-dot" data-i="2"></div>
      <div class="pin-dot" data-i="3"></div>
    </div>

    <!-- Numpad -->
    <div id="numpad" style="display:grid;grid-template-columns:repeat(3,1fr);gap:.6rem">
      <button class="np-btn" onclick="enterPin('1')">1</button>
      <button class="np-btn" onclick="enterPin('2')">2</button>
      <button class="np-btn" onclick="enterPin('3')">3</button>
      <button class="np-btn" onclick="enterPin('4')">4</button>
      <button class="np-btn" onclick="enterPin('5')">5</button>
      <button class="np-btn" onclick="enterPin('6')">6</button>
      <button class="np-btn" onclick="enterPin('7')">7</button>
      <button class="np-btn" onclick="enterPin('8')">8</button>
      <button class="np-btn" onclick="enterPin('9')">9</button>
      <button class="np-btn np-clear" onclick="clearPin()">✕</button>
      <button class="np-btn" onclick="enterPin('0')">0</button>
      <button class="np-btn np-del" onclick="delPin()">⌫</button>
    </div>

    <!-- Error msg -->
    <div id="pinError" style="
      text-align:center;margin-top:1rem;
      font-size:.72rem;color:#FF8A8A;font-weight:600;
      opacity:0;transition:opacity .2s;min-height:1rem;
    ">Λάθος κωδικός. Δοκιμάστε ξανά.</div>
  </div>

  <!-- Travelers hint -->
  <div style="margin-top:1.8rem;display:flex;gap:.6rem;flex-wrap:wrap;justify-content:center;position:relative">
    <div style="display:flex;align-items:center;gap:.4rem;
      background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);
      border-radius:100px;padding:.3rem .8rem .3rem .4rem;font-size:.7rem;color:rgba(255,255,255,.7)">
      <div style="display:flex">
        <div style="width:22px;height:22px;border-radius:50%;border:2px solid rgba(255,255,255,.3);
          background:linear-gradient(135deg,#8B1A1A,#C05030);
          display:flex;align-items:center;justify-content:center;font-size:.6rem;font-weight:700;color:white">Π</div>
        <div style="width:22px;height:22px;border-radius:50%;border:2px solid rgba(255,255,255,.3);
          background:linear-gradient(135deg,#A52020,#D04040);margin-left:-6px;
          display:flex;align-items:center;justify-content:center;font-size:.6rem;font-weight:700;color:white">Α</div>
      </div>
      <span style="color:#e05c7a">♥</span> Παυλίνα &amp; Ανδρέας
    </div>
    <div style="display:flex;align-items:center;gap:.4rem;
      background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);
      border-radius:100px;padding:.3rem .8rem .3rem .4rem;font-size:.7rem;color:rgba(255,255,255,.7)">
      <div style="display:flex">
        <div style="width:22px;height:22px;border-radius:50%;border:2px solid rgba(255,255,255,.3);
          background:linear-gradient(135deg,#1A5C8B,#2E86C1);
          display:flex;align-items:center;justify-content:center;font-size:.6rem;font-weight:700;color:white">Γ</div>
        <div style="width:22px;height:22px;border-radius:50%;border:2px solid rgba(255,255,255,.3);
          background:linear-gradient(135deg,#1A6B8B,#2E9EC1);margin-left:-6px;
          display:flex;align-items:center;justify-content:center;font-size:.6rem;font-weight:700;color:white">Σ</div>
      </div>
      <span style="color:#e05c7a">♥</span> Γιώργος &amp; Σανια
    </div>
  </div>
</div>

<style>
.pin-dot{
  width:14px;height:14px;border-radius:50%;
  border:2px solid rgba(255,255,255,.3);
  background:transparent;
  transition:all .15s;
}
.pin-dot.filled{
  background:#E8B45A;
  border-color:#E8B45A;
  box-shadow:0 0 8px rgba(232,180,90,.5);
  transform:scale(1.1);
}
.pin-dot.error{
  background:#FF5A5A;border-color:#FF5A5A;
  animation:shake .3s ease;
}
.np-btn{
  background:rgba(255,255,255,.08);
  border:1px solid rgba(255,255,255,.1);
  border-radius:12px;
  color:white;font-size:1.2rem;font-weight:600;
  padding:.9rem .5rem;
  font-family:'Fraunces',serif;
  cursor:pointer;transition:all .12s;
  -webkit-tap-highlight-color:transparent;
}
.np-btn:hover{background:rgba(255,255,255,.18);border-color:rgba(255,255,255,.25);transform:scale(1.04)}
.np-btn:active{transform:scale(.95);background:rgba(255,255,255,.25)}
.np-clear{color:#FF8A8A;font-size:.9rem;font-family:'Plus Jakarta Sans',sans-serif}
.np-del{font-size:1rem;font-family:'Plus Jakarta Sans',sans-serif}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}
@keyframes unlockPulse{0%{transform:scale(1)}50%{transform:scale(1.02)}100%{transform:scale(1);opacity:0}}
</style>

<script>
var pin = '';
var correct = '2727';
function enterPin(d) {
  if (pin.length >= 4) return;
  pin += d;
  updateDots();
  if (pin.length === 4) {
    setTimeout(checkPin, 120);
  }
}
function delPin() {
  pin = pin.slice(0,-1);
  updateDots();
  clearError();
}
function clearPin() {
  pin = '';
  updateDots();
  clearError();
}
function updateDots() {
  document.querySelectorAll('.pin-dot').forEach(function(d,i) {
    d.classList.toggle('filled', i < pin.length);
    d.classList.remove('error');
  });
}
function clearError() {
  document.getElementById('pinError').style.opacity = '0';
}
function checkPin() {
  if (pin === correct) {
    // Unlock animation
    var ls = document.getElementById('lockScreen');
    ls.style.transition = 'opacity .5s ease, transform .5s ease';
    ls.style.opacity = '0';
    ls.style.transform = 'scale(1.03)';
    setTimeout(function(){ ls.style.display = 'none'; }, 500);
  } else {
    // Error shake
    var err = document.getElementById('pinError');
    err.style.opacity = '1';
    document.querySelectorAll('.pin-dot').forEach(function(d) {
      d.classList.remove('filled');
      d.classList.add('error');
    });
    setTimeout(function(){
      pin = '';
      updateDots();
    }, 600);
  }
}
</script>


